  <property name="styleSheet">
   <string notr="true">/* Diseño SCADA / Industrial Dark Mode */
QWidget { background-color: #2b2b2b; color: #e0e0e0; font-family: &quot;Segoe UI&quot;, sans-serif; }

/* Estilo para las Pestañas */
QTabWidget::pane { border: 1px solid #444444; border-radius: 4px; }
QTabBar::tab { background: #3a3a3a; color: #aaaaaa; padding: 8px 20px; border: 1px solid #444; border-bottom: none; border-top-left-radius: 6px; border-top-right-radius: 6px; margin-right: 2px; }
QTabBar::tab:selected { background: #0275d8; color: white; font-weight: bold; }
QTabBar::tab:hover:!selected { background: #4a4a4a; }

/* Cajas de Agrupación */
QGroupBox { border: 1px solid #444444; border-radius: 6px; margin-top: 15px; font-weight: bold; }
QGroupBox::title { subcontrol-origin: margin; subcontrol-position: top left; padding: 0 5px; color: #5bc0de; }

/* Botones Generales */
QPushButton { border-radius: 4px; padding: 6px 12px; font-weight: bold; color: white; border: none; background-color: #555555;}
QPushButton:hover { background-color: #777777; }
QPushButton:pressed { background-color: #333333; }

/* Botones Específicos */
QPushButton#btnConectar { background-color: #0275d8; }
QPushButton#btnConectar:hover { background-color: #33b5e5; }
QPushButton#btnStart { background-color: #5cb85c; }
QPushButton#btnStart:hover { background-color: #449d44; }
QPushButton#btnStop { background-color: #d9534f; }
QPushButton#btnStop:hover { background-color: #c9302c; }
QPushButton#btnReset { background-color: #f0ad4e; }
QPushButton#btnReset:hover { background-color: #ec971f; }

/* Cajas de Texto y Entradas */
QTextEdit, QLineEdit { background-color: #1e1e1e; color: #00ff00; border: 1px solid #444; border-radius: 4px; font-family: &quot;Consolas&quot;, monospace; font-size: 12px; }
QLineEdit { color: #ffffff; font-size: 14px; font-weight: bold; padding-left: 5px;}

QLabel#lblEstado { font-weight: bold; color: #f0ad4e; font-size: 13px; }
QLabel { font-weight: bold; }
   </string>
